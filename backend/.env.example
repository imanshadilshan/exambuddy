# Application
APP_NAME=ExamBuddy
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-min-32-characters-long
API_V1_PREFIX=/api/v1

# Database (Neon PostgreSQL) - Add your connection string here
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname
DB_ECHO=False

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (for caching and sessions)
# Preferred for Upstash/serverless Redis (use this for production):
# REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=

# Cloudinary (File Storage)
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=exambuddy

# Payment Integration (PayHere - Sri Lanka)
# Get credentials from: https://www.payhere.lk/merchant/
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
PAYHERE_MODE=sandbox
PAYHERE_CURRENCY=LKR

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Email Configuration (Optional - for notifications)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@exambuddy.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Celery (Background Tasks)
CELERY_BROKER_URL=rediss://default:<password>@<endpoint>.upstash.io:6379/0
CELERY_RESULT_BACKEND=rediss://default:<password>@<endpoint>.upstash.io:6379/0

# OAuth2 Configuration (Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
